# ─── Banco de dados ───────────────────────────────
DATABASE_URL=postgresql+asyncpg://noc_user:senha_segura@localhost:5432/noc_db

# ─── Configurações gerais ─────────────────────────
APP_ENV=production
APP_SECRET=troque_para_chave_aleatoria_longa

# ─── Autenticação JWT ─────────────────────────────
# Gere uma chave segura: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=troque_para_chave_aleatoria_longa
JWT_ALGORITMO=HS256
JWT_EXPIRACAO_MINUTOS=480

# ─── Thresholds de alerta ─────────────────────────
# Latência em ms para considerar WARNING
LATENCY_WARN_MS=100
# Latência em ms para considerar CRITICAL
LATENCY_CRIT_MS=300
# Perda de pacotes % para CRITICAL
PACKET_LOSS_CRIT=20

# ─── Intervalo de ping por tipo (segundos) ────────
PING_INTERVAL_SERVER=30
PING_INTERVAL_RADIO=30
PING_INTERVAL_CORPORATE=60
PING_INTERVAL_POP=30

# ─── CORS (separar por vírgula) ───────────────────
# Ex: http://192.168.1.50,http://192.168.1.51
CORS_ORIGINS=http://localhost,http://127.0.0.1