[Unit]
Description=NOC Visual — API FastAPI
After=network.target postgresql.service

[Service]
Type=simple
User=noc
WorkingDirectory=/opt/noc-backend
ExecStart=/opt/noc-backend/venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8000 --workers 2
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

# Variáveis de ambiente — ou use EnvironmentFile=/opt/noc-backend/.env
EnvironmentFile=/opt/noc-backend/.env

[Install]
WantedBy=multi-user.target
